# Panel 访问口令（必填）
PANEL_PASSWORD=your_password_here

# 各提供商的 API Key（按需填写）
LONGCAT_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
SENSENOVA_API_KEY=
XIAOMI_API_KEY=
ZAI_API_KEY=

# 代理设置（可选，境外 API 需要）
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# 直连域名（代理走不了的国内 API）
NO_PROXY=token.sensenova.cn,open.bigmodel.cn
