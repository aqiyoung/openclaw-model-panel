# 面板登录口令（必填）
PANEL_PASSWORD=CHANGE_MY_PASSWORD

# --- 以下按需配置 ---

# 配置文件路径（默认: ~/.openclaw/openclaw.json）
# PANEL_CONFIG=~/.hermes/config.json

# 会话文件路径（默认: ~/.openclaw/agents/main/sessions/sessions.json）
# PANEL_SESSIONS=~/.hermes/sessions.json

# systemd 服务名（默认: openclaw-gateway.service）
# PANEL_SERVICE=hermes.service

# 代理（如果需要访问境外 API）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=internal.api.com
